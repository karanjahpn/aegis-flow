# AEGIS-FLOW :: Environment Configuration
# =========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Monitor Settings ──────────────────────────────────────────────────
AEGIS_INTERVAL=2.0
AEGIS_AUTO_HEAL=true
AEGIS_LOG_FILE=logs/alerts.jsonl
AEGIS_MAX_VIOLATIONS=3

# ── Blockchain Settings (optional) ────────────────────────────────────
# Set AEGIS_BLOCKCHAIN_ENABLED=true to anchor state hashes on-chain.
# Works with any EVM-compatible chain (Ethereum, Polygon, Hardhat, etc.)
AEGIS_BLOCKCHAIN_ENABLED=false

# RPC endpoint — examples:
#   Local Hardhat node : http://127.0.0.1:8545
#   Infura Sepolia     : https://sepolia.infura.io/v3/YOUR_KEY
#   Alchemy Polygon    : https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
AEGIS_RPC_URL=http://127.0.0.1:8545

# Deployed AegisRegistry contract address (from `npm run deploy:local`)
AEGIS_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Ethereum private key for submitting transactions (Hardhat test key shown)
# REPLACE WITH YOUR OWN KEY — never use a funded mainnet key in dev
AEGIS_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── Etherscan / Block Explorer (for contract verification) ────────────
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
